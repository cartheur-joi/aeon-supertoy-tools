{
  "name": "aeon-supertoy-tools",
  "displayName": "AEON Supertoy Tools",
  "description": "Syntax highlighting for AEON files, with optional aeonlint integration.",
  "version": "0.1.0",
  "publisher": "cartheur",
  "engines": {
    "vscode": "^1.84.0"
  },
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cartheur-joi/aeon-supertoy-tools.git"
  },
  "homepage": "https://github.com/cartheur-joi/aeon-supertoy-tools#readme",
  "bugs": {
    "url": "https://github.com/cartheur-joi/aeon-supertoy-tools/issues"
  },
  "keywords": [
    "aeon",
    "syntax",
    "grammar",
    "linter"
  ],
  "categories": [
    "Programming Languages",
    "Linters"
  ],
  "galleryBanner": {
    "color": "#0f172a",
    "theme": "dark"
  },
  "icon": "icon.jpg",
  "main": "./extension.js",
  "files": [
    "extension.js",
    "language-configuration.json",
    "syntaxes/**",
    "scripts/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "icon.jpg"
  ],
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "activationEvents": [
    "onLanguage:aeon",
    "onCommand:aeon.validateCurrentFile",
    "onCommand:aeon.validateWorkspace"
  ],
  "contributes": {
    "languages": [
      {
        "id": "aeon",
        "aliases": [
          "AEON",
          "aeon"
        ],
        "extensions": [
          ".aeon"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aeon",
        "scopeName": "source.aeon",
        "path": "./syntaxes/aeon.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "aeon.validateCurrentFile",
        "title": "AEON: Validate Current File"
      },
      {
        "command": "aeon.validateWorkspace",
        "title": "AEON: Validate Workspace"
      }
    ],
    "configuration": {
      "title": "AEON",
      "properties": {
        "aeon.validateOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run aeonlint for .aeon files when saved."
        }
      }
    }
  }
}
